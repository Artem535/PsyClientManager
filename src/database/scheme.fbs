
table ObxClient {
    id: ulong;
    name: string;
    last_name: string;
    additional_info: string;
    diagnosis: string;
    /// objectbox: date
    birthday_date: int64;
}

table ObxEvent {
    id: ulong;
    
    name: string;
    description: string;

    is_work_event: bool;

    /// objectbox: relation=EventStatus
    event_stat_id: ulong;
    /// objectbox: relation=PaymentStatus
    payment_stat_id: ulong;
    
    /// objectbox: date
    start_date: int64;
    /// objectbox: date
    end_date: int64;
    
    duration: int64;
}

table ObxPaymentStatus {
    id: ulong;
    name: string;
}

table ObxEventStatus {
    id: ulong;
    name: string;
}


